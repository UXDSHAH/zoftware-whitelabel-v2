# Zain Chat / Vertex AI Gemini
# Mirrors the embedded zain repo provider setup in zain/lib/ai/providers.ts.

NEXT_PUBLIC_PROVIDER=vertex
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=global

# Optional override. Defaults to gemini-3.5-flash to match the embedded Zain repo.
# Set to gemini-2.5-flash if that is the enabled Flash model in your Vertex project.
GOOGLE_VERTEX_MODEL=gemini-3.5-flash

# Service account credentials for Vercel or any runtime without gcloud ADC.
# Locally, you can leave these unset if `gcloud auth application-default login` is configured.
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional chat tracing.
# Enables AI SDK OpenTelemetry spans for /api/chat.
ZAIN_CHAT_TELEMETRY=false

# LangSmith trace content mode:
# - In local dev and Vercel preview/development, full content is captured by default
#   unless you set ZAIN_CHAT_TRACE_MODE=summary or ZAIN_CHAT_TRACE_CONTENT=false.
# - In production, traces stay summarized unless you explicitly set one of:
#   ZAIN_CHAT_TRACE_MODE=full or ZAIN_CHAT_TRACE_CONTENT=true.
# Full mode captures prompts, responses, tool inputs, and tool outputs.
ZAIN_CHAT_TRACE_MODE=summary
# Backward-compatible boolean override.
ZAIN_CHAT_TRACE_CONTENT=false

# Optional LangSmith project settings for the exporter/wrapper layer.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=zain-whitelabel
